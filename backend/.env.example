# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=contact_book
DB_USER=root
DB_PASSWORD=yourPassword

# ── Flask ─────────────────────────────────
SECRET_KEY=your key
FLASK_ENV=development
FLASK_APP=run.py

# ── File Uploads ──────────────────────────
UPLOAD_FOLDER=uploads
# 16MB in bytes:
MAX_CONTENT_LENGTH=16777216

# ── CORS ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
